{
  "name": "ARTales",
  "short_name": "ARTales",
  "description": "An online library for calm reading, curated collections and a reader community around literature.",
  "id": "/?source=pwa",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "background_color": "#f7efe2",
  "theme_color": "#0b0d10",
  "orientation": "any",
  "categories": [
    "books",
    "education",
    "entertainment"
  ],
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icons/artales-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/artales-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/artales-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/artales-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Library",
      "short_name": "Library",
      "description": "Open the ARTales library gallery.",
      "url": "/gallery?source=pwa",
      "icons": [
        {
          "src": "/icons/artales-icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "My account",
      "short_name": "Account",
      "description": "Open your ARTales account.",
      "url": "/account?source=pwa",
      "icons": [
        {
          "src": "/icons/artales-icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ]
}